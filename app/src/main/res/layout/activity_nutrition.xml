<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_nutrition"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".view.activity.NutritionActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/appbar_nutrition"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:padding="16dp"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/text_nutrition_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dinh dưỡng"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        android:paddingBottom="88dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appbar_nutrition">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


        <LinearLayout
            android:id="@+id/sectionMealLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/editLogDate"
                style="@style/AppInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="yyyy-MM-dd"
                android:inputType="date" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLoadLogs"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:text="Tải" />

            <TextView
                android:id="@+id/textEmptyLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/text_secondary"
                android:text="Chưa có bữa ăn trong ngày này" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMealLogs"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionMealPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/editPlanDate"
                style="@style/AppInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="yyyy-MM-dd"
                android:inputType="date" />

            <Spinner
                android:id="@+id/spinnerPlanMealType"
                android:layout_width="match_parent"
                android:layout_marginTop="12dp"
                android:layout_height="48dp" />

            <EditText
                android:id="@+id/editPlanFoodName"
                style="@style/AppInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Tên món"
                android:inputType="text" />

            <EditText
                android:id="@+id/editPlanCalories"
                style="@style/AppInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Calories"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editPlanProtein"
                style="@style/AppInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Protein"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editPlanCarbs"
                style="@style/AppInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Carbs"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editPlanFat"
                style="@style/AppInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Fat"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editPlanNote"
                style="@style/AppInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Ghi chú"
                android:inputType="textMultiLine" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSavePlan"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:text="Lưu kế hoạch" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLoadPlans"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/surface_soft"
                android:textColor="@color/primary_dark"
                android:text="Tải kế hoạch" />

            <TextView
                android:id="@+id/textEmptyPlans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/text_secondary"
                android:text="Chưa có kế hoạch cho ngày này" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMealPlans"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_bottom_nav" />

</androidx.constraintlayout.widget.ConstraintLayout>
