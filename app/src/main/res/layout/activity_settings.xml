<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cài đặt"
            android:textColor="#163426"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textUserEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="email@example.com"
            android:textColor="#65736B" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Mục tiêu dinh dưỡng"
            android:textColor="#163426"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editGoalCalories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Calories mục tiêu"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/editGoalProtein"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Protein mục tiêu"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/editGoalCarbs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Carbs mục tiêu"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/editGoalFat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fat mục tiêu"
            android:inputType="numberDecimal" />

        <Button
            android:id="@+id/buttonSaveGoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lưu mục tiêu" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Nhắc ghi nhận bữa ăn"
            android:textColor="#163426"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/switchReminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bật nhắc nhở" />

        <EditText
            android:id="@+id/editBreakfastTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Giờ sáng HH:mm"
            android:inputType="time" />

        <EditText
            android:id="@+id/editLunchTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Giờ trưa HH:mm"
            android:inputType="time" />

        <EditText
            android:id="@+id/editDinnerTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Giờ tối HH:mm"
            android:inputType="time" />

        <Button
            android:id="@+id/buttonSaveReminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lưu nhắc nhở" />

        <Button
            android:id="@+id/buttonLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Đăng xuất" />
    </LinearLayout>
</ScrollView>
