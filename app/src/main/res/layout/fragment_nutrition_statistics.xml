<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding">

            <!-- RANGE SELECTOR -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroupRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@+id/btnRange7">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRange7"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="7 ngày"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRange30"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="30 ngày"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRangeCustom"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tùy chọn"
                    android:textAllCaps="false" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:id="@+id/textRangeDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="04/07/2026 – 10/07/2026"
                android:textAppearance="@style/TextAppearance.App.BodySecondary" />

            <!-- OVERVIEW CARD -->
            <include
                android:id="@+id/cardStatsOverview"
                layout="@layout/card_statistics_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />

            <!-- CALORIES TREND -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                app:cardBackgroundColor="@color/surface"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Card"
                app:cardElevation="@dimen/card_elevation"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XU HƯỚNG CALORIES"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Lượng calories đã nạp theo từng ngày."
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartCaloriesTrend"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MACRO DISTRIBUTION -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                app:cardBackgroundColor="@color/surface"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Card"
                app:cardElevation="@dimen/card_elevation"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHÂN BỐ NĂNG LƯỢNG"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Tỷ lệ năng lượng từ protein, carb và chất béo."
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/chartMacroDist"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AVERAGE MACRO PROGRESS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_margin"
                app:cardBackgroundColor="@color/surface"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Card"
                app:cardElevation="@dimen/card_elevation"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRUNG BÌNH MACRO"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textStyle="bold" />

                    <!-- Protein -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_macro_protein"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="Protein"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Protein"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/textAvgProtein"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="86 / 120 g"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressAvgProtein"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:progressDrawable="@drawable/bg_horizontal_progress" />

                    <!-- Carbs -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_macro_carbs"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="Carbs"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Carbs"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/textAvgCarbs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="210 / 250 g"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressAvgCarbs"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:progressDrawable="@drawable/bg_horizontal_progress" />

                    <!-- Fat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_macro_fat"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="Fat"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Fat"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/textAvgFat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="58 / 65 g"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressAvgFat"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:progressDrawable="@drawable/bg_horizontal_progress" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- INSIGHTS -->
            <include
                android:id="@+id/cardStatsInsight"
                layout="@layout/card_statistics_insight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
