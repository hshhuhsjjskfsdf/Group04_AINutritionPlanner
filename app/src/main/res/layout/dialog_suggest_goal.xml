<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tính mục tiêu gợi ý"
        android:textAppearance="@style/TextAppearance.App.Title" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Dựa trên TDEE của bạn, hãy chọn mục tiêu:"
        android:textAppearance="@style/TextAppearance.App.BodySecondary" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGoalType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:checkedButton="@+id/btnMaintain"
        app:selectionRequired="true"
        app:singleSelection="true">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLose"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Giảm cân"
            android:textAllCaps="false" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMaintain"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Giữ cân"
            android:textAllCaps="false" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGain"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tăng cân"
            android:textAllCaps="false" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/surface_soft"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:id="@+id/textSuggestedValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mục tiêu gợi ý: 1.500 kcal/ngày"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Protein, Carbs và Fat sẽ được cân đối theo tỉ lệ lành mạnh."
                android:textAppearance="@style/TextAppearance.App.Caption" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="* Thông tin chỉ mang tính tham khảo và không thay thế tư vấn chuyên môn."
        android:textAppearance="@style/TextAppearance.App.Caption"
        android:textStyle="italic" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hủy" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            style="@style/AppButtonPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1.5"
            android:text="Áp dụng mục tiêu"
            android:enabled="false"/>
    </LinearLayout>

</LinearLayout>
