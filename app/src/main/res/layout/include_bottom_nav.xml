<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent">

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav_main"
        android:layout_width="0dp"
        android:layout_height="84dp"
        android:background="@color/surface"
        android:elevation="18dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        app:itemActiveIndicatorStyle="@null"
        app:itemIconSize="24dp"
        app:itemIconTint="@color/primary"
        app:itemRippleColor="@color/primary_light"
        app:itemTextColor="@color/text_primary"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/menu_bottom_nav" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_meal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Ghi nhận bữa ăn"
        android:elevation="24dp"
        android:src="@drawable/ic_add_meal"
        app:backgroundTint="@color/primary"
        app:borderWidth="0dp"
        app:fabCustomSize="72dp"
        app:layout_constraintBottom_toBottomOf="@id/bottom_nav_main"
        app:layout_constraintEnd_toEndOf="@id/bottom_nav_main"
        app:layout_constraintStart_toStartOf="@id/bottom_nav_main"
        app:layout_constraintTop_toTopOf="@id/bottom_nav_main"
        app:maxImageSize="34dp"
        app:tint="@color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>
