<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ghi nhận bữa ăn"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chọn món từ dữ liệu CSV, nhập thủ công hoặc phân tích ảnh bằng AI"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/imagePreview"
                        android:layout_width="match_parent"
                        android:layout_height="210dp"
                        android:background="@drawable/bg_empty_state"
                        android:contentDescription="Ảnh món ăn được chọn"
                        android:padding="16dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_camera" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/buttonChooseImage"
                            style="@style/AppButtonSecondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:contentDescription="Chọn ảnh món ăn từ thư viện"
                            android:text="Chọn ảnh" />

                        <Button
                            android:id="@+id/buttonCaptureImage"
                            style="@style/AppButtonSecondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:contentDescription="Chụp ảnh món ăn bằng camera"
                            android:text="Chụp ảnh" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/buttonAnalyzeFood"
                        style="@style/AppButtonPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Phân tích AI" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/textRecognitionResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_light"
                android:padding="16dp"
                android:text="AI sẵn sàng. Nếu chưa có model, bạn vẫn có thể nhập món thủ công."
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tìm món ăn"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/editSearchFood"
                        style="@style/AppInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Nhập tên món từ CSV"
                        android:inputType="text" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerFoods"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="10dp"
                        android:nestedScrollingEnabled="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thông tin dinh dưỡng"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/editFoodName"
                        style="@style/AppInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Tên món ăn"
                        android:inputType="text" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/editCalories"
                            style="@style/AppInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Calories"
                            android:inputType="numberDecimal" />

                        <EditText
                            android:id="@+id/editProtein"
                            style="@style/AppInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:hint="Protein"
                            android:inputType="numberDecimal" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/editCarbs"
                            style="@style/AppInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Carbs"
                            android:inputType="numberDecimal" />

                        <EditText
                            android:id="@+id/editFat"
                            style="@style/AppInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:hint="Fat"
                            android:inputType="numberDecimal" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/editServing"
                        style="@style/AppInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Khẩu phần"
                        android:inputType="text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Loại bữa ăn"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none">

                        <RadioGroup
                            android:id="@+id/groupMealType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/radioBreakfast"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:background="@drawable/selector_meal_chip"
                                android:button="@null"
                                android:checked="true"
                                android:gravity="center"
                                android:minWidth="92dp"
                                android:text="Sáng"
                                android:textColor="@color/selector_chip_text" />

                            <RadioButton
                                android:id="@+id/radioLunch"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/selector_meal_chip"
                                android:button="@null"
                                android:gravity="center"
                                android:minWidth="92dp"
                                android:text="Trưa"
                                android:textColor="@color/selector_chip_text" />

                            <RadioButton
                                android:id="@+id/radioDinner"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/selector_meal_chip"
                                android:button="@null"
                                android:gravity="center"
                                android:minWidth="92dp"
                                android:text="Tối"
                                android:textColor="@color/selector_chip_text" />

                            <RadioButton
                                android:id="@+id/radioSnack"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/selector_meal_chip"
                                android:button="@null"
                                android:gravity="center"
                                android:minWidth="92dp"
                                android:text="Phụ"
                                android:textColor="@color/selector_chip_text" />
                        </RadioGroup>
                    </HorizontalScrollView>

                    <Button
                        android:id="@+id/buttonSaveMeal"
                        style="@style/AppButtonPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Lưu bữa ăn" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/loadingView"
        layout="@layout/include_loading_view" />
</FrameLayout>
