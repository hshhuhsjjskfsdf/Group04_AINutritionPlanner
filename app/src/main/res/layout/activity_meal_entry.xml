<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_meal_entry"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".view.activity.MealEntryActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view_camera"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/camera_top_gradient"
        android:layout_width="0dp"
        android:layout_height="172dp"
        android:background="@drawable/bg_overlay_top_gradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/camera_bottom_gradient"
        android:layout_width="0dp"
        android:layout_height="360dp"
        android:background="@drawable/bg_overlay_bottom_gradient"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btn_close_camera"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="22dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Đóng camera"
        android:padding="12dp"
        android:src="@drawable/ic_close"
        android:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_camera_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="96dp"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:text="Nhận diện món ăn"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_close_camera"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_camera_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:text="AI Nutrition Planner"
        android:textColor="#D9FFFFFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@id/text_camera_title"
        app:layout_constraintStart_toStartOf="@id/text_camera_title"
        app:layout_constraintTop_toBottomOf="@id/text_camera_title" />

    <LinearLayout
        android:id="@+id/camera_floating_actions"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/btn_shutter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_camera_hint">

        <ImageButton
            android:id="@+id/btn_flash_toggle"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_camera_action"
            android:contentDescription="Bật hoặc tắt flash"
            android:padding="13dp"
            android:scaleType="center"
            android:src="@drawable/ic_flash"
            android:tint="@color/white" />

        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_camera_action"
            android:contentDescription="Lật camera"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_flip_camera"
            android:tint="@color/white" />

        <ImageButton
            android:id="@+id/btn_open_gallery"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_camera_action"
            android:contentDescription="Mở thư viện"
            android:padding="13dp"
            android:scaleType="center"
            android:src="@drawable/ic_gallery"
            android:tint="@color/white" />

        <ImageButton
            android:id="@+id/btn_manual_entry"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_camera_action"
            android:contentDescription="Nhập thủ công"
            android:padding="13dp"
            android:scaleType="center"
            android:src="@drawable/ic_edit_food"
            android:tint="@color/white" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_shutter"
        android:layout_width="104dp"
        android:layout_height="104dp"
        android:layout_marginBottom="42dp"
        android:background="@drawable/bg_shutter_button"
        android:contentDescription="Chụp ảnh món ăn"
        android:elevation="24dp"
        android:scaleType="center"
        android:src="@drawable/ic_nav_spacer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/camera_result_sheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="164dp"
        app:cardBackgroundColor="#80000000"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/camera_floating_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#26FFFFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/text_camera_result_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bữa ăn mới"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_camera_result_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Kết quả calo và macro sẽ xuất hiện tại đây."
                android:textColor="#D9FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:id="@+id/legacy_meal_entry_bindings"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imagePreview"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:contentDescription="Ảnh món ăn được chọn"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_camera" />

            <Button
                android:id="@+id/buttonChooseImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn ảnh" />

            <Button
                android:id="@+id/buttonCaptureImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chụp ảnh" />

            <Button
                android:id="@+id/buttonAnalyzeFood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phân tích AI" />

            <TextView
                android:id="@+id/textRecognitionResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI sẵn sàng." />

            <EditText
                android:id="@+id/editSearchFood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập tên món từ CSV"
                android:inputType="text" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerFoods"
                android:layout_width="1dp"
                android:layout_height="1dp" />

            <EditText
                android:id="@+id/editFoodName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên món ăn"
                android:inputType="text" />

            <EditText
                android:id="@+id/editCalories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Calories"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editProtein"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Protein"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editCarbs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Carbs"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editFat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fat"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editServing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Khẩu phần"
                android:inputType="text" />

            <RadioGroup
                android:id="@+id/groupMealType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radioBreakfast"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Sáng" />

                <RadioButton
                    android:id="@+id/radioLunch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trưa" />

                <RadioButton
                    android:id="@+id/radioDinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tối" />

                <RadioButton
                    android:id="@+id/radioSnack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phụ" />
            </RadioGroup>

            <Button
                android:id="@+id/buttonSaveMeal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lưu bữa ăn" />
        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/loadingView"
        layout="@layout/include_loading_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
