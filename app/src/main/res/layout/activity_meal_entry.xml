<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_meal_entry"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".view.activity.MealEntryActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view_camera"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/captured_image_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="Ảnh đã chụp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/camera_top_gradient"
        android:layout_width="0dp"
        android:layout_height="172dp"
        android:background="@drawable/bg_overlay_top_gradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/camera_bottom_gradient"
        android:layout_width="0dp"
        android:layout_height="360dp"
        android:background="@drawable/bg_overlay_bottom_gradient"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btn_close_camera"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="22dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Đóng camera"
        android:padding="12dp"
        android:src="@drawable/ic_close"
        android:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_camera_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="96dp"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:text="Nhận diện món ăn"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_close_camera"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_camera_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:text="AI Nutrition Planner"
        android:textColor="#D9FFFFFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="@id/text_camera_title"
        app:layout_constraintStart_toStartOf="@id/text_camera_title"
        app:layout_constraintTop_toBottomOf="@id/text_camera_title" />

    <LinearLayout
        android:id="@+id/camera_floating_actions"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/btn_shutter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_camera_hint">

        <ImageButton
            android:id="@+id/btn_flash_toggle"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_camera_action"
            android:contentDescription="Bật hoặc tắt flash"
            android:padding="13dp"
            android:scaleType="center"
            android:src="@drawable/ic_flash"
            android:tint="@color/white" />

        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_camera_action"
            android:contentDescription="Lật camera"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_flip_camera"
            android:tint="@color/white" />

        <ImageButton
            android:id="@+id/btn_open_gallery"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_camera_action"
            android:contentDescription="Mở thư viện"
            android:padding="13dp"
            android:scaleType="center"
            android:src="@drawable/ic_gallery"
            android:tint="@color/white" />

        <ImageButton
            android:id="@+id/btn_manual_entry"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_camera_action"
            android:contentDescription="Nhập thủ công"
            android:padding="13dp"
            android:scaleType="center"
            android:src="@drawable/ic_edit_food"
            android:tint="@color/white" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_shutter"
        android:layout_width="104dp"
        android:layout_height="104dp"
        android:layout_marginBottom="42dp"
        android:background="@drawable/bg_shutter_button"
        android:contentDescription="Chụp ảnh món ăn"
        android:elevation="24dp"
        android:scaleType="center"
        android:src="@drawable/ic_nav_spacer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btn_retake_photo"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="62dp"
        android:layout_marginStart="32dp"
        android:background="@drawable/bg_camera_action"
        android:contentDescription="Chụp lại"
        android:elevation="24dp"
        android:scaleType="center"
        android:src="@drawable/ic_close"
        android:tint="@color/white"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/camera_result_sheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="164dp"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/camera_floating_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#4DFFFFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/text_camera_result_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phân tích bữa ăn"
                android:textAppearance="@style/TextAppearance.App.Headline"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/text_camera_result_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Nhấn Chụp để bắt đầu, sau đó bấm Phân tích."
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textColor="#D9FFFFFF" />

            <!-- Bảng Macro kết quả (Mặc định ẩn) -->
            <LinearLayout
                android:id="@+id/layout_macro_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calo"
                        android:textColor="#99FFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/text_result_calories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary_light"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protein"
                        android:textColor="#99FFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/text_result_protein"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carbs"
                        android:textColor="#99FFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/text_result_carbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fat"
                        android:textColor="#99FFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/text_result_fat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonAnalyzeSelectedFood"
                    style="@style/AppButtonPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Phân tích AI"
                    android:textAllCaps="false" />
                    
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSaveCameraMeal"
                    style="@style/AppButtonPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Lưu bữa ăn"
                    android:textAllCaps="false"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Form Nhập thủ công & Kết quả Tìm kiếm CSV ẩn đi ban đầu -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_manual_entry"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@color/surface"
        android:visibility="gone"
        android:elevation="30dp"
        android:paddingTop="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_close_manual"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:src="@drawable/ic_close"
            android:tint="@color/text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhập thủ công"
                android:textAppearance="@style/TextAppearance.App.Headline"
                app:layout_constraintBottom_toBottomOf="@id/btn_close_manual"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_close_manual" />

        <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:padding="@dimen/screen_padding"
            android:layout_marginTop="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_close_manual">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/img_manual_food"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_empty_bowl"
                        android:background="@drawable/bg_card_light"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Card" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_change_manual_image"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="12dp"
                        android:text="Thay ảnh"
                        app:icon="@drawable/ic_camera" />
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tìm kiếm món ăn (từ Database)"
                    android:textAppearance="@style/TextAppearance.App.BodySecondary"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/editSearchFood"
                    style="@style/AppInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nhập tên món ăn để tìm..."
                    android:drawablePadding="12dp"
                    android:inputType="text" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerFoods"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_light"
                    android:clipToPadding="false"
                    android:padding="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Thông tin Dinh dưỡng"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/editFoodName"
                    style="@style/AppInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tên món ăn"
                    android:inputType="text" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">
                    
                    <EditText
                        android:id="@+id/editCalories"
                        style="@style/AppInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Calories"
                        android:inputType="numberDecimal" />

                    <EditText
                        android:id="@+id/editServing"
                        style="@style/AppInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:hint="Khẩu phần"
                        android:inputType="text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/editProtein"
                        style="@style/AppInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Protein (g)"
                        android:inputType="numberDecimal" />

                    <EditText
                        android:id="@+id/editCarbs"
                        style="@style/AppInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:hint="Carbs (g)"
                        android:inputType="numberDecimal" />

                    <EditText
                        android:id="@+id/editFat"
                        style="@style/AppInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:hint="Fat (g)"
                        android:inputType="numberDecimal" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loại bữa ăn"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/groupMealType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioBreakfast"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="Sáng" />

                    <RadioButton
                        android:id="@+id/radioLunch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Trưa" />

                    <RadioButton
                        android:id="@+id/radioDinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tối" />

                    <RadioButton
                        android:id="@+id/radioSnack"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Phụ" />
                </RadioGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSaveMeal"
                    style="@style/AppButtonPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="88dp"
                    android:text="Lưu bữa ăn" />
            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
    
    <LinearLayout android:id="@+id/legacy_bindings" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone">
        <ImageView android:id="@+id/imagePreview" android:layout_width="1dp" android:layout_height="1dp" />
        <Button android:id="@+id/buttonChooseImage" android:layout_width="1dp" android:layout_height="1dp" />
        <Button android:id="@+id/buttonCaptureImage" android:layout_width="1dp" android:layout_height="1dp" />
        <Button android:id="@+id/buttonAnalyzeFood" android:layout_width="1dp" android:layout_height="1dp" />
        <TextView android:id="@+id/textRecognitionResult" android:layout_width="1dp" android:layout_height="1dp" />
    </LinearLayout>

    <include
        android:id="@+id/loadingView"
        layout="@layout/include_loading_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
