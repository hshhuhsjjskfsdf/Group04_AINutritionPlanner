<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/textMealName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên món"
        android:textColor="#163426"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textMealMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Breakfast • yyyy-MM-dd"
        android:textColor="#65736B" />

    <TextView
        android:id="@+id/textMealMacros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="0 kcal | P 0g • C 0g • F 0g"
        android:textColor="#3E5146" />

    <Button
        android:id="@+id/buttonDeleteMeal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="Xóa" />
</LinearLayout>
